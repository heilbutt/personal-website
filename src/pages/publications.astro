---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const publications = await getCollection('publications');
---
<BaseLayout title="Publications">
    <ul>
        {publications.map((pub) => (
            <li>
                <strong>{pub.data['title']}</strong><br />
                <em>{pub.data['container-title']}</em> 
                ({pub.data.issued.toLocaleDateString('en-US', { 
                    year: 'numeric', month: 'long', day: 'numeric' 
                })})
                <br />
                <span>
                {pub.data.author.map((auth, index) => (
                    <span>{auth.given} {auth.family}{index < pub.data.author.length - 1 ? ', ' : ''}</span>
                ))}
                </span>
            </li>
        ))}
</ul>
</BaseLayout>